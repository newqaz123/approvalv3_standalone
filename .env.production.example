# Production Environment Variables Template
# Copy this file to .env.production and fill in the actual values
#
# Where to get values:
# - Clerk keys: https://dashboard.clerk.com/apps
# - PostgreSQL: Use internal Docker networking (db service)
#
# SECURITY WARNING: Never commit .env.production to version control

# ==============================================
# Clerk Authentication
# ==============================================
# Get keys from: https://dashboard.clerk.com/apps
# Create a new application and copy the keys from the API Keys section
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_secret_key_here

# Clerk Webhook Secret (optional, for webhook verification)
# After deploying, create webhook at https://dashboard.clerk.com
# Endpoint: https://your-domain.com/api/webhooks/clerk
# Copy the signing secret from webhook settings
CLERK_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ==============================================
# Database Configuration (Docker Internal)
# ==============================================
# In Docker Compose, use the internal service name 'db' for the host
# The database credentials must match the db service configuration in docker-compose.yml
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=app_db

# Constructed DATABASE_URL for Docker internal networking
# Format: postgresql://user:password@host:port/database
# Host: db (Docker Compose service name)
# Port: 5432 (default PostgreSQL port)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# ==============================================
# Next.js Configuration
# ==============================================
# The public URL of your deployed application
# Required for NextAuth and Clerk webhooks
# Example: https://approval.yourdomain.com
NEXTAUTH_URL=https://your-domain.com

# NextAuth Secret (generate a random string)
# Used to encrypt JWT tokens
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here_generate_with_openssl

# ==============================================
# Application Environment
# ==============================================
# Set to production for optimized builds and error handling
NODE_ENV=production

# ==============================================
# File Upload Configuration
# ==============================================
# Directory for file uploads (mounted as volume in Docker Compose)
UPLOAD_DIR=public/uploads

# ==============================================
# Cron Job Secret (if using cron jobs)
# ==============================================
# Secret for securing cron job endpoints
# Generate with: openssl rand -base64 32
CRON_SECRET=your_cron_secret_here_generate_with_openssl

# ==============================================
# Puppeteer Configuration
# ==============================================
# Path to Chromium browser for PDF generation in Docker
# Default for Alpine Linux with Chromium installed
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
# Skip downloading Chromium during npm install (we install via Dockerfile)
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
