generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model department_approvers {
  id            String      @id
  departmentId  String
  approverId    String
  approverLevel Int
  createdAt     DateTime    @default(now())
  updatedAt     DateTime
  users         User       @relation(fields: [approverId], references: [id], onDelete: Cascade)
  departments   departments @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([departmentId, approverId, approverLevel])
  @@index([approverId])
  @@index([departmentId])
}

model departments {
  id                    String                  @id
  name                  String                  @unique
  type                  DepartmentType
  createdAt             DateTime                @default(now())
  updatedAt             DateTime
  levelNames            Json?
  department_approvers  department_approvers[]
  hierarchy_change_logs hierarchy_change_logs[]
  requests              requests[]
  users                 User[]
}

model file_attachments {
  id           String     @id
  requestId    String?
  fileName     String
  fileType     String
  fileSize     Int
  description  String?
  uploadedById String
  createdAt    DateTime   @default(now())
  filePath     String
  solutionId   String?
  requests     requests?  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  solutions    solutions? @relation(fields: [solutionId], references: [id], onDelete: Cascade)
  users        User      @relation(fields: [uploadedById], references: [id])

  @@index([requestId])
  @@index([solutionId])
  @@index([uploadedById])
}

model hierarchy_change_logs {
  id                                              String      @id
  departmentId                                    String
  adminUserId                                     String
  targetUserId                                    String
  oldLevel                                        Int?
  newLevel                                        Int
  reason                                          String?
  createdAt                                       DateTime    @default(now())
  users_hierarchy_change_logs_adminUserIdTousers  User       @relation("hierarchy_change_logs_adminUserIdTousers", fields: [adminUserId], references: [id])
  departments                                     departments @relation(fields: [departmentId], references: [id])
  users_hierarchy_change_logs_targetUserIdTousers User       @relation("hierarchy_change_logs_targetUserIdTousers", fields: [targetUserId], references: [id])

  @@index([adminUserId])
  @@index([createdAt])
  @@index([departmentId])
  @@index([targetUserId])
}

model notifications {
  id        String           @id
  userId    String
  type      NotificationType
  title     String
  message   String
  requestId String?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())
  requests  requests?        @relation(fields: [requestId], references: [id], onDelete: Cascade)
  users     User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([isRead])
  @@index([userId])
}

model request_activities {
  id         String         @id
  requestId  String?
  action     String
  fromStatus RequestStatus?
  toStatus   RequestStatus?
  comments   String?
  userId     String
  createdAt  DateTime       @default(now())
  requests   requests?      @relation(fields: [requestId], references: [id], onDelete: Cascade)
  users      User          @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([requestId])
  @@index([userId])
}

model request_approvals {
  id                                                String         @id
  requestId                                         String
  approverId                                        String?
  requiredLevel                                     Int
  order                                             Int
  status                                            ApprovalStatus @default(pending)
  comments                                          String?
  approvedAt                                        DateTime?
  createdAt                                         DateTime       @default(now())
  isCustomChain                                     Boolean        @default(false)
  isFinalApproval                                   Boolean        @default(false)
  requiredApproverId                                String?
  users_request_approvals_approverIdTousers         User?         @relation("request_approvals_approverIdTousers", fields: [approverId], references: [id])
  requests                                          requests       @relation(fields: [requestId], references: [id], onDelete: Cascade)
  users_request_approvals_requiredApproverIdTousers User?         @relation("request_approvals_requiredApproverIdTousers", fields: [requiredApproverId], references: [id])

  @@index([approverId])
  @@index([requestId])
  @@index([requiredApproverId])
  @@index([requiredLevel])
  @@index([status])
}

model request_engineer_assignments {
  id           String   @id
  requestId    String
  engineerId   String
  assignedAt   DateTime @default(now())
  assignedById String?
  users        User    @relation(fields: [engineerId], references: [id])
  requests     requests @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([engineerId])
  @@index([requestId])
}

model requests {
  id                                String                         @id
  title                             String
  description                       String
  status                            RequestStatus                  @default(ImprovementRequest)
  requesterId                       String
  departmentId                      String
  createdAt                         DateTime                       @default(now())
  updatedAt                         DateTime
  engineeringCostEstimate           Decimal?                       @db.Decimal(15, 2)
  engineeringSolution               String?
  deletedAt                         DateTime?
  deletedBy                         String?
  isDeleted                         Boolean                        @default(false)
  isArchived                        Boolean                        @default(false)
  file_attachments                  file_attachments[]
  notifications                     notifications[]
  request_activities                request_activities[]
  request_approvals                 request_approvals[]
  request_engineer_assignments      request_engineer_assignments[]
  users_requests_deletedByTousers   User?                         @relation("requests_deletedByTousers", fields: [deletedBy], references: [id])
  departments                       departments                    @relation(fields: [departmentId], references: [id])
  users_requests_requesterIdTousers User                          @relation("requests_requesterIdTousers", fields: [requesterId], references: [id])
  solutions                         solutions[]

  @@index([createdAt])
  @@index([departmentId])
  @@index([isDeleted])
  @@index([requesterId])
  @@index([status])
}

model solution_approvals {
  id                                                 String         @id
  solutionId                                         String
  requiredLevel                                      Int?
  requiredApproverId                                 String?
  approverId                                         String?
  order                                              Int
  status                                             ApprovalStatus @default(pending)
  comments                                           String?
  isCustomChain                                      Boolean        @default(false)
  approvedAt                                         DateTime?
  createdAt                                          DateTime       @default(now())
  users_solution_approvals_approverIdTousers         User?         @relation("solution_approvals_approverIdTousers", fields: [approverId], references: [id])
  users_solution_approvals_requiredApproverIdTousers User?         @relation("solution_approvals_requiredApproverIdTousers", fields: [requiredApproverId], references: [id])
  solutions                                          solutions      @relation(fields: [solutionId], references: [id], onDelete: Cascade)

  @@index([approverId])
  @@index([order])
  @@index([requiredApproverId])
  @@index([solutionId])
  @@index([status])
}

model solutions {
  id                 String               @id
  requestId          String
  title              String
  description        String
  costEstimate       Decimal              @db.Decimal(15, 2)
  currency           String               @default("THB")
  timeline           String?
  conceptDesign      String?
  submittedById      String
  submittedAt        DateTime             @default(now())
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  file_attachments   file_attachments[]
  solution_approvals solution_approvals[]
  requests           requests             @relation(fields: [requestId], references: [id], onDelete: Cascade)
  users              User                @relation(fields: [submittedById], references: [id])

  @@index([createdAt])
  @@index([requestId])
  @@index([submittedById])
}

model templates {
  id          String   @id
  name        String
  title       String
  description String
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  @@index([isActive])
  @@index([isDefault])
}

model User {
  id                                                              String                         @id
  email                                                           String                         @unique
  name                                                            String
  departmentId                                                    String?
  role                                                            UserRole                       @default(general_dept)
  level                                                           Int?
  isActive                                                        Boolean                        @default(true)
  createdAt                                                       DateTime                       @default(now())
  updatedAt                                                       DateTime
  department_approvers                                            department_approvers[]
  file_attachments                                                file_attachments[]
  hierarchy_change_logs_hierarchy_change_logs_adminUserIdTousers  hierarchy_change_logs[]        @relation("hierarchy_change_logs_adminUserIdTousers")
  hierarchy_change_logs_hierarchy_change_logs_targetUserIdTousers hierarchy_change_logs[]        @relation("hierarchy_change_logs_targetUserIdTousers")
  notifications                                                   notifications[]
  request_activities                                              request_activities[]
  request_approvals_request_approvals_approverIdTousers           request_approvals[]            @relation("request_approvals_approverIdTousers")
  request_approvals_request_approvals_requiredApproverIdTousers   request_approvals[]            @relation("request_approvals_requiredApproverIdTousers")
  request_engineer_assignments                                    request_engineer_assignments[]
  requests_requests_deletedByTousers                              requests[]                     @relation("requests_deletedByTousers")
  requests_requests_requesterIdTousers                            requests[]                     @relation("requests_requesterIdTousers")
  solution_approvals_solution_approvals_approverIdTousers         solution_approvals[]           @relation("solution_approvals_approverIdTousers")
  solution_approvals_solution_approvals_requiredApproverIdTousers solution_approvals[]           @relation("solution_approvals_requiredApproverIdTousers")
  solutions                                                       solutions[]
  department                                                     departments?                   @relation(fields: [departmentId], references: [id])

  @@index([departmentId])
  @@index([isActive])
  @@index([level])
  @@map("users")
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

enum DepartmentType {
  GENERAL
  ENGINEERING
}

enum NotificationType {
  approval_needed
  approval_granted
  approval_rejected
  status_changed
  request_assigned
  solution_ready
  final_approval_needed
}

enum RequestStatus {
  ImprovementRequest
  SentToEngineer
  SendBackToRequester
  Completed
  Cancelled
  DesignCostEstimationApproval
  FinalApproval
}

enum UserRole {
  admin
  general_dept
  engineering
}
