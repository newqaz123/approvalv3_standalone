generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model department_approvers {
  id            String      @id @default(uuid())
  departmentId  String
  approverId    String
  approverLevel Int
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  approver      User       @relation(fields: [approverId], references: [id], onDelete: Cascade)
  department    departments @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([departmentId, approverId, approverLevel])
  @@index([approverId])
  @@index([departmentId])
}

model departments {
  id                    String                  @id @default(uuid())
  name                  String                  @unique
  type                  DepartmentType
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  levelNames            Json?
  departmentApprovers   department_approvers[]
  hierarchyChangeLogs   hierarchy_change_logs[]
  requests              requests[]
  users                 User[]
}

model file_attachments {
  id           String     @id @default(uuid())
  requestId    String?
  fileName     String
  fileType     String
  fileSize     Int
  description  String?
  uploadedById String
  createdAt    DateTime   @default(now())
  filePath     String
  solutionId   String?
  request      requests?  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  solution     solutions? @relation(fields: [solutionId], references: [id], onDelete: Cascade)
  uploadedBy   User      @relation(fields: [uploadedById], references: [id])

  @@index([requestId])
  @@index([solutionId])
  @@index([uploadedById])
}

model hierarchy_change_logs {
  id                                              String      @id @default(uuid())
  departmentId                                    String
  adminUserId                                     String
  targetUserId                                    String
  oldLevel                                        Int?
  newLevel                                        Int
  reason                                          String?
  createdAt                                       DateTime    @default(now())
  adminUser                                       User       @relation("hierarchy_change_logs_adminUserIdTousers", fields: [adminUserId], references: [id])
  department                                      departments @relation(fields: [departmentId], references: [id])
  targetUser                                      User       @relation("hierarchy_change_logs_targetUserIdTousers", fields: [targetUserId], references: [id])

  @@index([adminUserId])
  @@index([createdAt])
  @@index([departmentId])
  @@index([targetUserId])
}

model notifications {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  requestId String?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())
  request   requests?        @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([isRead])
  @@index([userId])
}

model request_activities {
  id         String         @id @default(uuid())
  requestId  String?
  action     String
  fromStatus RequestStatus?
  toStatus   RequestStatus?
  comments   String?
  userId     String
  createdAt  DateTime       @default(now())
  request    requests?      @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user       User          @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([requestId])
  @@index([userId])
}

model request_approvals {
  id                                                String         @id @default(uuid())
  requestId                                         String
  approverId                                        String?
  requiredLevel                                     Int
  order                                             Int
  status                                            ApprovalStatus @default(pending)
  comments                                          String?
  approvedAt                                        DateTime?
  createdAt                                         DateTime       @default(now())
  isCustomChain                                     Boolean        @default(false)
  isFinalApproval                                   Boolean        @default(false)
  requiredApproverId                                String?
  approver                                          User?         @relation("request_approvals_approverIdTousers", fields: [approverId], references: [id])
  request                                           requests       @relation(fields: [requestId], references: [id], onDelete: Cascade)
  requiredApprover                                  User?         @relation("request_approvals_requiredApproverIdTousers", fields: [requiredApproverId], references: [id])

  @@index([approverId])
  @@index([requestId])
  @@index([requiredApproverId])
  @@index([requiredLevel])
  @@index([status])
}

model request_engineer_assignments {
  id           String   @id @default(uuid())
  requestId    String
  engineerId   String
  assignedAt   DateTime @default(now())
  assignedById String?
  engineer     User    @relation(fields: [engineerId], references: [id])
  request      requests @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([engineerId])
  @@index([requestId])
}

model budget_codes {
  id           String     @id @default(uuid())
  code         String     @unique
  displayCode  String
  budgetAmount Decimal?   @db.Decimal(15, 2)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  requests     requests[]

  @@index([displayCode])
}

model requests {
  id                                String                         @id @default(uuid())
  title                             String
  description                       String
  status                            RequestStatus                  @default(ImprovementRequest)
  requesterId                       String
  departmentId                      String
  createdAt                         DateTime                       @default(now())
  updatedAt                         DateTime                       @updatedAt
  engineeringCostEstimate           Decimal?                       @db.Decimal(15, 2)
  engineeringSolution               String?
  deletedAt                         DateTime?
  deletedBy                         String?
  isDeleted                         Boolean                        @default(false)
  isArchived                        Boolean                        @default(false)
  budgetCodeId                      String?
  projectEstimateCost               Decimal?                       @db.Decimal(15, 2)
  fileAttachments                   file_attachments[]
  notifications                     notifications[]
  activities                        request_activities[]
  approvals                         request_approvals[]
  engineerAssignments               request_engineer_assignments[]
  budgetCode                        budget_codes?                 @relation(fields: [budgetCodeId], references: [id], onDelete: SetNull)
  deletedByUser                     User?                         @relation("requests_deletedByTousers", fields: [deletedBy], references: [id])
  department                        departments                    @relation(fields: [departmentId], references: [id])
  requester                         User                          @relation("requests_requesterIdTousers", fields: [requesterId], references: [id])
  solutions                         solutions[]

  @@index([budgetCodeId])
  @@index([createdAt])
  @@index([departmentId])
  @@index([isDeleted])
  @@index([requesterId])
  @@index([status])
}

model solution_approvals {
  id                                                 String         @id @default(uuid())
  solutionId                                         String
  requiredLevel                                      Int?
  requiredApproverId                                 String?
  approverId                                         String?
  order                                              Int
  status                                             ApprovalStatus @default(pending)
  comments                                           String?
  isCustomChain                                      Boolean        @default(false)
  approvedAt                                         DateTime?
  createdAt                                          DateTime       @default(now())
  approver                                           User?         @relation("solution_approvals_approverIdTousers", fields: [approverId], references: [id])
  requiredApprover                                   User?         @relation("solution_approvals_requiredApproverIdTousers", fields: [requiredApproverId], references: [id])
  solution                                           solutions      @relation(fields: [solutionId], references: [id], onDelete: Cascade)

  @@index([approverId])
  @@index([order])
  @@index([requiredApproverId])
  @@index([solutionId])
  @@index([status])
}

model solutions {
  id                 String               @id @default(uuid())
  requestId          String
  title              String
  description        String
  costEstimate       Decimal              @db.Decimal(15, 2)
  currency           String               @default("THB")
  timeline           String?
  conceptDesign      String?
  submittedById      String
  submittedAt        DateTime             @default(now())
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  fileAttachments    file_attachments[]
  approvals          solution_approvals[]
  request            requests             @relation(fields: [requestId], references: [id], onDelete: Cascade)
  submittedBy        User                @relation(fields: [submittedById], references: [id])

  @@index([createdAt])
  @@index([requestId])
  @@index([submittedById])
}

model templates {
  id          String   @id @default(uuid())
  name        String
  title       String
  description String
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([isDefault])
}

model User {
  id                                                              String                         @id @default(uuid())
  email                                                           String                         @unique
  name                                                            String
  passwordHash                                                    String?
  departmentId                                                    String?
  role                                                            UserRole                       @default(general_dept)
  level                                                           Int?
  isActive                                                        Boolean                        @default(true)
  forcePasswordChange                                             Boolean                        @default(false)
  createdAt                                                       DateTime                       @default(now())
  updatedAt                                                       DateTime                       @updatedAt
  departmentApproverRoles                                        department_approvers[]
  fileAttachments                                                file_attachments[]
  adminHierarchyChanges                                          hierarchy_change_logs[]        @relation("hierarchy_change_logs_adminUserIdTousers")
  targetHierarchyChanges                                         hierarchy_change_logs[]        @relation("hierarchy_change_logs_targetUserIdTousers")
  notifications                                                   notifications[]
  requestActivities                                              request_activities[]
  approvedRequests                                               request_approvals[]            @relation("request_approvals_approverIdTousers")
  requiredApprovalRequests                                       request_approvals[]            @relation("request_approvals_requiredApproverIdTousers")
  engineerAssignments                                            request_engineer_assignments[]
  deletedRequests                                                requests[]                     @relation("requests_deletedByTousers")
  createdRequests                                                requests[]                     @relation("requests_requesterIdTousers")
  approvedSolutions                                              solution_approvals[]           @relation("solution_approvals_approverIdTousers")
  requiredApprovalSolutions                                      solution_approvals[]           @relation("solution_approvals_requiredApproverIdTousers")
  solutions                                                       solutions[]
  department                                                     departments?                   @relation(fields: [departmentId], references: [id])

  @@index([departmentId])
  @@index([isActive])
  @@index([level])
  @@map("users")
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

enum DepartmentType {
  GENERAL
  ENGINEERING
}

enum NotificationType {
  approval_needed
  approval_granted
  approval_rejected
  status_changed
  request_assigned
  solution_ready
  final_approval_needed
}

enum RequestStatus {
  ImprovementRequest
  SentToEngineer
  SendBackToRequester
  Completed
  Cancelled
  DesignCostEstimationApproval
  FinalApproval
}

enum UserRole {
  admin
  general_dept
  engineering
}
