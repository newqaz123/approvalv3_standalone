{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "clerk": {
      "type": "remote",
      "url": "https://mcp.clerk.com/mcp",
      "enabled": true
    },
    "neon": {
      "type": "remote",
      "url": "https://mcp.neon.tech/mcp",
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    }
  },
  "agent": {
    "gsd-planner": { "model": "zai-coding-plan/glm-4.7" },
    "gsd-plan-checker": { "model": "zai-coding-plan/glm-4.7" },
    "gsd-phase-researcher": { "model": "zai-coding-plan/glm-4.7" },
    "gsd-roadmapper": { "model": "zai-coding-plan/glm-4.7" },
    "gsd-project-researcher": { "model": "zai-coding-plan/glm-4.7" },
    "gsd-research-synthesizer": { "model": "zai-coding-plan/glm-4.7" },
    "gsd-codebase-mapper": { "model": "zai-coding-plan/glm-4.7" },
    "gsd-executor": { "model": "opencode/minimax-m2.5-free" },
    "gsd-debugger": { "model": "opencode/minimax-m2.5-free" },
    "gsd-verifier": { "model": "zai-coding-plan/glm-4.7" },
    "gsd-integration-checker": { "model": "zai-coding-plan/glm-4.7" },
    "gsd-set-profile": { "model": "zai-coding-plan/glm-4.7" },
    "gsd-settings": { "model": "zai-coding-plan/glm-4.7" },
    "gsd-set-model": { "model": "zai-coding-plan/glm-4.7" }
  }
}
